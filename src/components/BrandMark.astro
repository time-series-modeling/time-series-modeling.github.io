---
interface Props {
  class?: string;
  variant?: 'book-wave' | 'book-nodes' | 'book-pulse' | 'book-grid';
}

const { class: className = 'h-7 w-7', variant = 'book-wave' } = Astro.props;

const variantMap = {
  'book-wave': '/assets/brand/book-wave.svg',
  'book-nodes': '/assets/brand/book-nodes.svg',
  'book-pulse': '/assets/brand/book-pulse.svg',
  'book-grid': '/assets/brand/book-grid.svg',
} as const;

const src = variantMap[variant] ?? variantMap['book-wave'];
---

<img src={src} alt="" aria-hidden="true" class={className} loading="eager" decoding="async" />