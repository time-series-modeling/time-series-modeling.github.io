---
import '../styles/global.css';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import type { Translations } from '../i18n';
import type { SupportedLocale } from '../i18n';

interface Props {
  t: Translations;
  locale: SupportedLocale;
  title?: string;
  description?: string;
  currentPath?: string;
}

const { t, locale, title, description, currentPath = '/' } = Astro.props;
const pageTitle = title ? `${title} | ${t.siteTitle}` : t.siteTitle;
const pageDesc = description ?? t.siteDescription;
---

<!doctype html>
<html lang={locale} dir={t.dir} class="antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDesc} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-white text-slate-900">
    <Navigation t={t} locale={locale} currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <Footer t={t} locale={locale} />
  </body>
</html>
