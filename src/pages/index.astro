---
import Layout from '../layouts/Layout.astro';
import { getTranslations } from '../i18n';

const t = getTranslations('en');
const locale = 'en' as const;
---

<Layout t={t} locale={locale} currentPath="/">
  <!-- Hero Section -->
  <section
    class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-primary-950 to-slate-900 text-white"
  >
    <div class="absolute inset-0 opacity-20">
      <div
        class="absolute inset-0"
        style="background-image: radial-gradient(circle at 25% 25%, #3b82f6 0%, transparent 50%), radial-gradient(circle at 75% 75%, #8b5cf6 0%, transparent 50%);"
      >
      </div>
    </div>
    <div class="relative mx-auto max-w-6xl px-4 py-24 sm:px-6 lg:px-8 lg:py-32">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <span
            class="mb-4 inline-flex items-center gap-1.5 rounded-full border border-primary-500/30 bg-primary-500/10 px-3 py-1 text-sm font-medium text-primary-300"
          >
            <span class="h-1.5 w-1.5 rounded-full bg-primary-400"></span>
            {t.hero.badge}
          </span>
          <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl">
            {t.hero.title}
          </h1>
          <p class="mt-6 text-lg leading-relaxed text-slate-300 sm:text-xl">
            {t.hero.subtitle}
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href="#purchase"
              class="rounded-lg bg-primary-600 px-6 py-3 text-base font-semibold text-white shadow-lg transition-all hover:bg-primary-500 hover:shadow-primary-500/25 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-400"
            >
              {t.hero.buyNow}
            </a>
            <a
              href="#about"
              class="rounded-lg border border-white/20 bg-white/10 px-6 py-3 text-base font-semibold text-white backdrop-blur-sm transition-all hover:bg-white/20"
            >
              {t.hero.learnMore}
            </a>
          </div>
          <p class="mt-6 text-sm text-slate-400">
            {t.hero.publisherLabel}:
            <span class="font-medium text-slate-200">{t.hero.publisher}</span>
          </p>
        </div>

        <!-- Book cover mockup -->
        <div class="flex justify-center">
          <div
            class="relative w-56 rotate-3 rounded-2xl bg-gradient-to-br from-primary-600 to-accent-600 p-1 shadow-2xl shadow-primary-900/50 transition-transform hover:rotate-0 sm:w-64"
          >
            <div
              class="rounded-xl bg-slate-900 p-6 text-center"
            >
              <div class="text-6xl">📈</div>
              <div class="mt-4 text-xl font-bold leading-tight text-white">
                Time Series<br />with PyTorch
              </div>
              <div class="mt-3 text-xs text-slate-400">Lei Ma · Graeme Davidson</div>
              <div
                class="mt-4 rounded-md bg-gradient-to-r from-primary-600 to-accent-500 px-3 py-1.5 text-xs font-semibold text-white"
              >
                Packt Publishing
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About the Book -->
  <section id="about" class="py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
          {t.book.sectionTitle}
        </h2>
        <p class="mt-3 text-lg text-slate-500">{t.book.sectionSubtitle}</p>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        <p class="text-base leading-relaxed text-slate-600">{t.book.description}</p>
        <p class="text-base leading-relaxed text-slate-600">{t.book.description2}</p>
      </div>

      <!-- Feature cards -->
      <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          t.book.features.map((feature) => (
            <div class="group rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition-all hover:border-primary-200 hover:shadow-md hover:shadow-primary-100">
              <div class="mb-3 text-3xl">{feature.icon}</div>
              <h3 class="text-base font-semibold text-slate-900">{feature.title}</h3>
              <p class="mt-1 text-sm leading-relaxed text-slate-500">{feature.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Purchase Section -->
  <section id="purchase" class="bg-slate-50 py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
          {t.purchase.sectionTitle}
        </h2>
        <p class="mt-3 text-lg text-slate-500">{t.purchase.sectionSubtitle}</p>
      </div>
      <div class="mt-12 flex flex-wrap justify-center gap-6">
        {
          t.purchase.options.map((option) => (
            <a
              href={option.url}
              target="_blank"
              rel="noopener noreferrer"
              class={`flex w-full max-w-xs flex-col items-center rounded-2xl border p-8 text-center shadow-sm transition-all hover:shadow-md ${
                option.primary
                  ? 'border-primary-200 bg-primary-50 hover:border-primary-300'
                  : 'border-slate-200 bg-white hover:border-slate-300'
              }`}
            >
              <span class="text-4xl">{option.icon}</span>
              <span
                class={`mt-4 text-lg font-semibold ${option.primary ? 'text-primary-700' : 'text-slate-800'}`}
              >
                {option.name}
              </span>
              <span class="mt-1 text-sm text-slate-500">{option.description}</span>
              <span
                class={`mt-5 rounded-lg px-5 py-2 text-sm font-medium transition-colors ${
                  option.primary
                    ? 'bg-primary-600 text-white hover:bg-primary-700'
                    : 'bg-slate-100 text-slate-700 hover:bg-slate-200'
                }`}
              >
                {option.primary ? t.hero.buyNow : t.hero.learnMore} →
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Authors teaser -->
  <section class="py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
          {t.authors.sectionTitle}
        </h2>
        <p class="mt-3 text-lg text-slate-500">{t.authors.sectionSubtitle}</p>
      </div>
      <div class="mt-12 grid gap-8 sm:grid-cols-2">
        {
          t.authors.list.map((author) => (
            <div class="flex flex-col items-center rounded-2xl border border-slate-200 bg-white p-8 text-center shadow-sm">
              <div class="text-5xl">{author.avatar}</div>
              <h3 class="mt-4 text-xl font-bold text-slate-900">{author.name}</h3>
              <p class="mt-1 text-sm font-medium text-primary-600">{author.title}</p>
              <p class="mt-3 text-sm leading-relaxed text-slate-500 line-clamp-3">{author.bio}</p>
            </div>
          ))
        }
      </div>
      <div class="mt-8 text-center">
        <a
          href="/authors"
          class="inline-flex items-center gap-2 text-sm font-medium text-primary-600 hover:text-primary-800"
        >
          {t.authors.learnMoreAbout} →
        </a>
      </div>
    </div>
  </section>

  <!-- Social / Feedback CTA -->
  <section class="bg-gradient-to-br from-primary-600 to-accent-600 py-16 text-white">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h2 class="text-2xl font-bold sm:text-3xl">{t.feedback.sectionTitle}</h2>
      <p class="mt-3 text-primary-100">{t.feedback.intro}</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        {
          t.feedback.channels.map((ch) => (
            <a
              href={ch.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 rounded-lg bg-white/15 px-5 py-3 text-sm font-medium backdrop-blur-sm transition-all hover:bg-white/25"
            >
              <span>{ch.icon}</span>
              <span>{ch.linkText}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
