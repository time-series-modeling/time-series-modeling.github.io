---
import Layout from '../../layouts/Layout.astro';
import { getTranslations } from '../../i18n';

const t = getTranslations('zh');
const locale = 'zh' as const;
---

<Layout t={t} locale={locale} title={t.authors.sectionTitle} currentPath="/zh/authors">
  <div class="py-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center">
        <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">
          {t.authors.sectionTitle}
        </h1>
        <p class="mt-4 text-lg text-slate-500">{t.authors.sectionSubtitle}</p>
      </div>

      <!-- Author cards -->
      <div class="mt-16 space-y-16">
        {
          t.authors.list.map((author, idx) => (
            <div
              class={`flex flex-col gap-8 md:flex-row ${idx % 2 === 1 ? 'md:flex-row-reverse' : ''}`}
            >
              <!-- Avatar side -->
              <div class="flex shrink-0 flex-col items-center md:w-64">
                <div class="flex h-28 w-28 items-center justify-center rounded-full bg-gradient-to-br from-primary-100 to-accent-400/20 text-6xl shadow-md">
                  {author.avatar}
                </div>
                <h2 class="mt-4 text-xl font-bold text-slate-900">{author.name}</h2>
                <p class="mt-1 text-center text-sm font-medium text-primary-600">{author.title}</p>

                <!-- Links -->
                <div class="mt-4 flex gap-3">
                  {author.links.github && (
                    <a
                      href={author.links.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex h-9 w-9 items-center justify-center rounded-full border border-slate-200 text-slate-500 transition-colors hover:border-slate-900 hover:text-slate-900"
                      aria-label="GitHub"
                    >
                      <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                      </svg>
                    </a>
                  )}
                  {author.links.twitter && (
                    <a
                      href={author.links.twitter}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex h-9 w-9 items-center justify-center rounded-full border border-slate-200 text-slate-500 transition-colors hover:border-sky-500 hover:text-sky-500"
                      aria-label="Twitter"
                    >
                      <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                      </svg>
                    </a>
                  )}
                </div>
              </div>

              <!-- Bio side -->
              <div class="flex-1 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
                <p class="text-base leading-relaxed text-slate-600">{author.bio}</p>
                <div class="mt-6">
                  <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-slate-400">
                    {t.authors.expertiseLabel}
                  </h3>
                  <div class="flex flex-wrap gap-2">
                    {author.expertise.map((skill) => (
                      <span class="rounded-full bg-primary-50 px-3 py-1 text-xs font-medium text-primary-700">
                        {skill}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</Layout>
