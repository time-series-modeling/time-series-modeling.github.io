---
import Layout from '../../layouts/Layout.astro';
import { getTranslations } from '../../i18n';

const t = getTranslations('zh');
const locale = 'zh' as const;
---

<Layout t={t} locale={locale} currentPath="/zh/">
  <!-- Hero Section -->
  <section
    class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-primary-950 to-slate-900 text-white"
  >
    <div class="absolute inset-0 opacity-20">
      <div
        class="absolute inset-0"
        style="background-image: radial-gradient(circle at 25% 25%, #3b82f6 0%, transparent 50%), radial-gradient(circle at 75% 75%, #8b5cf6 0%, transparent 50%);"
      >
      </div>
    </div>
    <div class="relative mx-auto max-w-6xl px-4 py-24 sm:px-6 lg:px-8 lg:py-32">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <span
            class="mb-4 inline-flex items-center gap-1.5 rounded-full border border-primary-500/30 bg-primary-500/10 px-3 py-1 text-sm font-medium text-primary-300"
          >
            <span class="h-1.5 w-1.5 rounded-full bg-primary-400"></span>
            {t.hero.badge}
          </span>
          <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl">
            {t.hero.title}
          </h1>
          <p class="mt-6 text-lg leading-relaxed text-slate-300 sm:text-xl">
            {t.hero.subtitle}
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href="#purchase"
              class="rounded-lg bg-primary-600 px-6 py-3 text-base font-semibold text-white shadow-lg transition-all hover:bg-primary-500 hover:shadow-primary-500/25 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-400"
            >
              {t.hero.buyNow}
            </a>
            <a
              href="#about"
              class="rounded-lg border border-white/20 bg-white/10 px-6 py-3 text-base font-semibold text-white backdrop-blur-sm transition-all hover:bg-white/20"
            >
              {t.hero.learnMore}
            </a>
          </div>
          <p class="mt-6 text-sm text-slate-400">
            {t.hero.publisherLabel}:
            <span class="font-medium text-slate-200">{t.hero.publisher}</span>
          </p>
        </div>

        <!-- Book cover mockup -->
        <div class="flex justify-center">
          <div
            class="relative w-56 rotate-3 overflow-hidden rounded-2xl bg-gradient-to-br from-primary-600 to-accent-600 p-2 shadow-2xl shadow-primary-900/50 transition-transform hover:rotate-0 sm:w-64"
          >
            <img
              src="/assets/book-cover-en.png"
              alt="PyTorch 时间序列 书封面"
              class="block aspect-[2/3] h-auto w-full rounded-xl object-contain"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About the Book -->
  <section id="about" class="py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
          {t.book.sectionTitle}
        </h2>
        <p class="mt-3 text-lg text-slate-500">{t.book.sectionSubtitle}</p>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        <p class="text-base leading-relaxed text-slate-600">{t.book.description}</p>
        <p class="text-base leading-relaxed text-slate-600">{t.book.description2}</p>
      </div>

      <!-- Key benefits and learning outcomes -->
      <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          t.book.features.map((feature, idx) => (
            <div class="group rounded-2xl bg-gradient-to-br from-sky-100/80 via-white to-orange-100/80 p-[1px] shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
              <div class="h-full rounded-2xl bg-white/95 p-6 backdrop-blur-sm">
                <div class="flex items-center justify-between">
                  <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-slate-900 text-xl text-white shadow-sm">
                    {feature.icon}
                  </span>
                  <span class="text-xs font-semibold tracking-[0.2em] text-slate-400">
                    {String(idx + 1).padStart(2, '0')}
                  </span>
                </div>
                <h3 class="mt-5 text-base font-semibold leading-snug text-slate-900">
                  {feature.title}
                </h3>
                <p class="mt-2 text-sm leading-relaxed text-slate-600">{feature.desc}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Visual content map -->
  <section id="roadmap" class="relative overflow-hidden bg-slate-950 py-20 text-slate-100">
    <div class="absolute inset-0 opacity-40">
      <div
        class="absolute inset-0"
        style="background-image: radial-gradient(circle at 12% 20%, rgba(56, 189, 248, 0.22) 0%, transparent 36%), radial-gradient(circle at 90% 82%, rgba(251, 146, 60, 0.22) 0%, transparent 34%);"
      >
      </div>
    </div>
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-sky-300">{t.roadmap.badge}</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">
          {t.roadmap.sectionTitle}
        </h2>
        <p class="mt-3 text-lg text-slate-300">{t.roadmap.sectionSubtitle}</p>
        <p class="mt-5 text-sm leading-relaxed text-slate-400">{t.roadmap.intro}</p>
      </div>

      <div class="relative mt-12">
        <div class="pointer-events-none absolute left-8 right-8 top-10 hidden h-px bg-gradient-to-r from-sky-300/20 via-sky-300/60 to-orange-300/20 lg:block"></div>
        <div class="grid gap-6 lg:grid-cols-5">
          {
            t.roadmap.stages.map((stage, idx) => (
              <article class="relative rounded-2xl border border-white/12 bg-white/6 p-5 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-sky-300/40 hover:bg-white/10">
                <div class="mb-4 flex items-center justify-between">
                  <span class="rounded-full border border-sky-300/40 bg-sky-300/10 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.16em] text-sky-200">
                    {stage.phase}
                  </span>
                  <span class="text-xs font-semibold text-slate-400">{String(idx + 1).padStart(2, '0')}</span>
                </div>
                <h3 class="text-base font-semibold leading-snug text-white">{stage.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-slate-300">{stage.summary}</p>

                <div class="mt-4 flex flex-wrap gap-1.5">
                  {stage.chapters.map((chapter) => (
                    <span class="rounded-full border border-white/15 bg-white/8 px-2.5 py-1 text-[11px] font-medium text-slate-200">
                      {chapter}
                    </span>
                  ))}
                </div>

                <div class="mt-4 border-t border-white/10 pt-3">
                  <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-400">{t.roadmap.outcomesLabel}</p>
                  <ul class="mt-2 space-y-1.5">
                    {stage.outcomes.map((outcome) => (
                      <li class="flex items-start gap-2 text-xs leading-relaxed text-slate-300">
                        <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-orange-300"></span>
                        <span>{outcome}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Purchase Section -->
  <section id="purchase" class="bg-slate-50 py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
          {t.purchase.sectionTitle}
        </h2>
        <p class="mt-3 text-lg text-slate-500">{t.purchase.sectionSubtitle}</p>
      </div>
      <div class="mt-12 flex flex-wrap justify-center gap-6">
        {
          t.purchase.options.map((option) => (
            <a
              href={option.url}
              target="_blank"
              rel="noopener noreferrer"
              class={`flex w-full max-w-xs flex-col items-center rounded-2xl border p-8 text-center shadow-sm transition-all hover:shadow-md ${
                option.primary
                  ? 'border-primary-200 bg-primary-50 hover:border-primary-300'
                  : 'border-slate-200 bg-white hover:border-slate-300'
              }`}
            >
              <span class="text-4xl">{option.icon}</span>
              <span
                class={`mt-4 text-lg font-semibold ${option.primary ? 'text-primary-700' : 'text-slate-800'}`}
              >
                {option.name}
              </span>
              <span class="mt-1 text-sm text-slate-500">{option.description}</span>
              <span
                class={`mt-5 rounded-lg px-5 py-2 text-sm font-medium transition-colors ${
                  option.primary
                    ? 'bg-primary-600 text-white hover:bg-primary-700'
                    : 'bg-slate-100 text-slate-700 hover:bg-slate-200'
                }`}
              >
                {option.cta} →
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Authors teaser -->
  <section class="py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
          {t.authors.sectionTitle}
        </h2>
        <p class="mt-3 text-lg text-slate-500">{t.authors.sectionSubtitle}</p>
      </div>
      <div class="mt-12 grid gap-8 sm:grid-cols-2">
        {
          t.authors.list.map((author) => (
            <div class="flex flex-col items-center rounded-2xl border border-slate-200 bg-white p-8 text-center shadow-sm">
              <div class="text-5xl">{author.avatar}</div>
              <h3 class="mt-4 text-xl font-bold text-slate-900">{author.name}</h3>
              <p class="mt-1 text-sm font-medium text-primary-600">{author.title}</p>
              <p class="mt-3 text-sm leading-relaxed text-slate-500 line-clamp-3">{author.bio}</p>
            </div>
          ))
        }
      </div>
      <div class="mt-8 text-center">
        <a
          href="/zh/authors"
          class="inline-flex items-center gap-2 text-sm font-medium text-primary-600 hover:text-primary-800"
        >
          {t.authors.learnMoreAbout} →
        </a>
      </div>
    </div>
  </section>

  <!-- Social / Feedback CTA -->
  <section class="bg-gradient-to-br from-primary-600 to-accent-600 py-16 text-white">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h2 class="text-2xl font-bold sm:text-3xl">{t.feedback.sectionTitle}</h2>
      <p class="mt-3 text-primary-100">{t.feedback.intro}</p>
      <div class="mt-8 grid gap-3 text-left sm:grid-cols-3">
        {
          t.feedback.channels.map((ch) => (
            <div class="rounded-lg bg-white/15 p-3 backdrop-blur-sm transition-all hover:bg-white/20">
              <div class="mb-2 flex items-center gap-2 text-sm font-medium">
                <span>{ch.icon}</span>
                <span>{ch.title}</span>
              </div>
              <div class="flex flex-col gap-2">
                {
                  ch.links.map((link) => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 rounded-md bg-white/15 px-3 py-2 text-xs font-medium transition-colors hover:bg-white/25"
                    >
                      {
                        link.url.includes('linkedin.com') ? (
                          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.15 1.45-2.15 2.95v5.66H9.33V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.61 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45z" />
                          </svg>
                        ) : link.url.includes('github.com/') ? (
                          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 0 0 7.86 10.93c.57.1.78-.24.78-.54 0-.27-.01-.98-.02-1.93-3.2.7-3.88-1.54-3.88-1.54-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.23-1.28-5.23-5.68 0-1.25.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.73.8 1.18 1.83 1.18 3.08 0 4.41-2.68 5.39-5.24 5.68.41.36.78 1.07.78 2.15 0 1.55-.01 2.8-.01 3.18 0 .3.2.65.79.54A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5z" />
                          </svg>
                        ) : (
                          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h8M8 14h5M4 6h16a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H8l-4 4V8a2 2 0 0 1 2-2z" />
                          </svg>
                        )
                      }
                      <span>{link.name}</span>
                    </a>
                  ))
                }
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
