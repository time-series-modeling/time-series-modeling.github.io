---
import Layout from '../layouts/Layout.astro';
import { getTranslations } from '../i18n';

const t = getTranslations('en');
const locale = 'en' as const;
---

<Layout t={t} locale={locale} title={t.feedback.sectionTitle} currentPath="/feedback">
  <div class="py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center">
        <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">
          {t.feedback.sectionTitle}
        </h1>
        <p class="mt-4 text-lg text-slate-500">{t.feedback.sectionSubtitle}</p>
      </div>

      <p class="mt-8 text-center text-base leading-relaxed text-slate-600">
        {t.feedback.intro}
      </p>

      <!-- Channels -->
      <div class="mt-12 grid gap-6 sm:grid-cols-3">
        {
          t.feedback.channels.map((ch) => (
            <div class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition-all hover:border-primary-200 hover:shadow-md">
              <div class="text-4xl">{ch.icon}</div>
              <h3 class="mt-4 text-base font-semibold text-slate-900">{ch.title}</h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-500">{ch.desc}</p>
              <div class="mt-5 flex flex-wrap gap-2">
                {
                  ch.links.map((link) => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-1 rounded-md bg-primary-50 px-3 py-1.5 text-xs font-medium text-primary-700 transition-colors hover:bg-primary-100"
                    >
                      {link.name}
                    </a>
                  ))
                }
              </div>
            </div>
          ))
        }
      </div>

      <!-- Social links -->
      <div class="mt-16">
        <h2 class="text-center text-2xl font-bold text-slate-900">
          {t.feedback.social.title}
        </h2>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          {
            t.feedback.social.links.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 rounded-xl border border-slate-200 bg-white px-6 py-4 shadow-sm transition-all hover:border-primary-200 hover:shadow-md"
              >
                <span class="text-2xl">{link.icon}</span>
                <span class="text-sm font-medium text-slate-700">{link.name}</span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</Layout>
